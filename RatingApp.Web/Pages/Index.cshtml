@page
@using RatingApp.Domain.Entities
@model IndexModel
@{
    ViewData["Title"] = "Leagues";
}

<div class="text-center">
    <h1 class="display-4">There you can explore all leagues</h1><br/>
</div>

<div class="text-left">
    @foreach (LeagueEntity league in Model.Leagues)
    {
        <h2><a href="/League/@league.Id">@league.Name</a></h2>
    }
</div>
